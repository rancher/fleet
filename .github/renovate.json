{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>rancher/renovate-config//rancher-main#release"
  ],
  "baseBranchPatterns": [
    "main",
    "release/v0.14",
    "release/v0.13",
    "release/v0.12",
    "release/v0.11"
  ],
  "ignorePaths": [
    "**/assets/**"
  ],
  "packageRules": [
    {
      "description": "Update indirect dependencies in integrationtests/go.mod only when the same dependency is updated elsewhere in the workspace",
      "matchManagers": [
        "gomod"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "matchFileNames": [
        "integrationtests/go.mod"
      ],
      "enabled": true,
      "minimumGroupSize": 2
    },
    {
      "matchBaseBranches": [
        "release/v0.14"
      ],
      "extends": [
        "github>rancher/renovate-config//rancher-2.13#release"
      ]
    },
    {
      "matchBaseBranches": [
        "release/v0.13"
      ],
      "extends": [
        "github>rancher/renovate-config//rancher-2.12#release"
      ]
    },
    {
      "matchBaseBranches": [
        "release/v0.12"
      ],
      "extends": [
        "github>rancher/renovate-config//rancher-2.11#release"
      ]
    },
    {
      "matchBaseBranches": [
        "release/v0.11"
      ],
      "extends": [
        "github>rancher/renovate-config//rancher-2.10#release"
      ]
    }
  ]
}
